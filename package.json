{
  "name": "@azin-tech/mini-tools",
  "version": "0.2.1",
  "description": "Developer mini-tools: YAML, OpenAPI, JSON, Base64, Cron, Regex, Robots.txt, PostgreSQL, MySQL, UUID, Uptime, Dockerfile, JWT, Hash, Timestamp, DNS",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "mini-tools": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "bun test",
    "prepublishOnly": "bun run typecheck && bun run lint && bun run build"
  },
  "dependencies": {
    "@readme/openapi-parser": "^5.5.0",
    "commander": "^12.1.0",
    "cronstrue": "^2.50.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "bun-types": "^1.3.9",
    "tsup": "^8.5.1",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/azin-tech/mini-tools.git"
  },
  "bugs": {
    "url": "https://github.com/azin-tech/mini-tools/issues"
  },
  "homepage": "https://azin.run/tools",
  "keywords": [
    "yaml",
    "openapi",
    "json",
    "base64",
    "cron",
    "regex",
    "robots-txt",
    "postgresql",
    "mysql",
    "uuid",
    "uptime",
    "dockerfile",
    "jwt",
    "hash",
    "timestamp",
    "dns",
    "cli",
    "developer-tools",
    "mini-tools"
  ],
  "publishConfig": {
    "access": "public"
  }
}
